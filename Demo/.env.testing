# PhotonBlog 测试环境配置 (testing)

APP_PROFILE=test
APP_NAME=PhotonBlog
APP_VERSION=0.1.0
APP_DEBUG=true

APP_SERVER_HOST=127.0.0.1
APP_SERVER_PORT=0

DB_DRIVER=sqlite
DB_PATH=:memory:
DB_MAX_CONNS=5

JWT_SECRET=test-secret-key-for-testing-only-32chars
JWT_TTL=60
JWT_REFRESH_HOURS=24
JWT_ISSUER=PhotonBlog-Test

CACHE_DRIVER=memory
CACHE_TTL=60
CACHE_PREFIX=test:photonblog:

MAIL_DRIVER=log
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=test@photonblog.dev
MAIL_FROM_NAME=PhotonBlog-Test

STORAGE_DRIVER=local
STORAGE_BASE_PATH=./test_storage/uploads
STORAGE_MAX_SIZE=1048576
STORAGE_ALLOWED_EXT=jpg,jpeg,png

LOG_LEVEL=error
LOG_CHANNEL=stdout
LOG_FILE_PATH=./test_storage/logs/test.log
LOG_JSON_FORMAT=false

WEB_CORS_ALLOWED_ORIGINS=*
WEB_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
WEB_CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
WEB_RATE_LIMIT_MAX_REQUESTS=1000
WEB_RATE_LIMIT_WINDOW_SECS=60

AUTH_ROLE_HIERARCHY=ADMIN>EDITOR>USER

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@test.photonblog.dev
