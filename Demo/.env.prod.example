# PhotonBlog 生产环境配置模板 (prod)
# 复制为 .env.prod 并填入真实值
#   cp .env.prod.example .env.prod

APP_PROFILE=prod
APP_NAME=PhotonBlog
APP_VERSION=0.1.0
APP_DEBUG=false

APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=80

DB_DRIVER=sqlite
DB_PATH=/app/storage/photonblog.db
DB_MAX_CONNS=20

# ⚠️ 必须设置！生成方式：openssl rand -base64 48
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_HOURS=24
JWT_ISSUER=PhotonBlog

CACHE_DRIVER=memory
CACHE_TTL=3600
CACHE_PREFIX=photonblog:

MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@photonblog.com
MAIL_FROM_NAME=PhotonBlog

STORAGE_DRIVER=local
STORAGE_BASE_PATH=/app/storage/uploads
STORAGE_MAX_SIZE=5242880
STORAGE_ALLOWED_EXT=jpg,jpeg,png,gif,webp

LOG_LEVEL=info
LOG_CHANNEL=file
LOG_FILE_PATH=/app/storage/logs/app.log
LOG_JSON_FORMAT=true

WEB_CORS_ALLOWED_ORIGINS=https://photonblog.com
WEB_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
WEB_CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
WEB_RATE_LIMIT_MAX_REQUESTS=120
WEB_RATE_LIMIT_WINDOW_SECS=60

AUTH_ROLE_HIERARCHY=ADMIN>EDITOR>USER

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
SEED_ADMIN_EMAIL=admin@photonblog.com
