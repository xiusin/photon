# ═══════════════════════════════════════════════════════════
# PhotonBlog 环境变量模板
# ═══════════════════════════════════════════════════════════
# 复制此文件为 .env 并修改对应值
#   cp .env.example .env
#
# 环境文件加载优先级（后者覆盖前者）：
#   1. .env            — 基础环境变量
#   2. .env.<profile>  — profile 特定覆盖（.env.dev / .env.prod / .env.testing）
#   3. 系统环境变量    — 最高优先级
# ═══════════════════════════════════════════════════════════

# ── 应用配置 ──
APP_PROFILE=dev
APP_NAME=PhotonBlog
APP_VERSION=0.1.0
APP_DEBUG=true

# ── 服务器配置 ──
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=8080

# ── 数据库配置 ──
DB_DRIVER=sqlite
DB_PATH=:memory:
DB_MAX_CONNS=10

# ── JWT 配置 ──
# ⚠️ 生产环境必须设置！至少 32 字符的随机字符串
# 生成方式：openssl rand -base64 48
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_HOURS=24
JWT_ISSUER=PhotonBlog

# ── 缓存配置 ──
CACHE_DRIVER=memory
CACHE_TTL=3600
CACHE_PREFIX=photonblog:

# ── 邮件配置 ──
MAIL_DRIVER=log
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@photonblog.dev
MAIL_FROM_NAME=PhotonBlog

# ── 存储配置 ──
STORAGE_DRIVER=local
STORAGE_BASE_PATH=./storage/uploads
STORAGE_MAX_SIZE=5242880
STORAGE_ALLOWED_EXT=jpg,jpeg,png,gif,webp

# ── 日志配置 ──
LOG_LEVEL=debug
LOG_CHANNEL=stdout
LOG_FILE_PATH=./storage/logs/app.log
LOG_JSON_FORMAT=false

# ── Web 配置 ──
WEB_CORS_ALLOWED_ORIGINS=*
WEB_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
WEB_CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
WEB_RATE_LIMIT_MAX_REQUESTS=60
WEB_RATE_LIMIT_WINDOW_SECS=60

# ── 认证配置 ──
AUTH_ROLE_HIERARCHY=ADMIN>EDITOR>USER

# ── 种子数据配置 ──
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@photonblog.dev
